{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "paths": {
      "@footie/domain": ["packages/domain/src/index.ts"],
      "@footie/ui": ["packages/ui/src/index.ts"],
      "@footie/data-ingestion": ["services/data-ingestion/src/index.ts"]
    }
  }
}
